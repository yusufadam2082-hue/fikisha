NODE_ENV=production
PORT=10000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
JWT_SECRET=replace-with-a-long-random-secret
CORS_ORIGIN=https://your-site.netlify.app
ADMIN_PASSWORD=replace-with-a-strong-admin-password
MERCHANT_PASSWORD=replace-with-a-strong-merchant-password

# M-Pesa Daraja (production)
MPESA_ENVIRONMENT=production
MPESA_CONSUMER_KEY=replace-with-your-consumer-key
MPESA_CONSUMER_SECRET=replace-with-your-consumer-secret
MPESA_SHORTCODE=replace-with-your-shortcode
MPESA_PASSKEY=replace-with-your-passkey
MPESA_CALLBACK_URL=https://your-backend.onrender.com/api/payments/webhooks/mpesa
MPESA_WEBHOOK_SECRET=replace-with-a-secret-for-webhook-signature-validation
