// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String   @default("CUSTOMER")
  name      String
  email     String?
  phone     String?
  country   String?
  referralCode String?
  dateOfBirth DateTime?
  gender    String?
  address   String?
  storeId   String?
  banned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ownedStores Store[]         @relation("StoreOwner")
  orders      Order[]         @relation("OrderCustomer")
  driver      Driver?
  auditLogs   AdminAuditLog[] @relation("AdminAuditLogs")
  orderNotes  OrderNote[]     @relation("OrderNoteAdmin")
  notifications Notification[]
  broadcastsSent BroadcastCampaign[] @relation("BroadcastCreatedBy")
  paymentIntents PaymentIntent[]

  @@index([storeId])
  @@index([role])
}

model Store {
  id          String    @id @default(uuid())
  name        String
  rating      Float     @default(5.0)
  time        String    @default("15-25 min")
  deliveryFee Float     @default(2.99)
  category    String
  image       String
  bannerImage String?
  description String
  address     String?
  country     String?
  city        String?
  area        String?
  streetAddress String?
  buildingNumber String?
  landmark    String?
  latitude    Float?
  longitude   Float?
  deliveryRadiusKm Float?
  phone       String?
  isOpen      Boolean   @default(true)
  isActive    Boolean   @default(true)
  status      String    @default("PENDING_REVIEW")
  reviewNotes String?
  reviewRequestedDocs String?
  goLiveReady Boolean   @default(false)
  onboardingCompleted Boolean @default(false)
  orderPreparationTimeMin Int?
  minimumOrderAmount Float?
  deliveryMethod String?
  deliveryFeeType String?
  deliveryFeeValue Float?
  freeDeliveryThreshold Float?
  allowPickup Boolean @default(false)
  commissionRate  Float     @default(0)
  ownerIdDocument String?
  businessPermitDocument String?
  taxPin      String?
  proofOfAddressDocument String?
  verificationCompleted Boolean @default(false)
  payoutMethod String?
  bankName    String?
  accountName String?
  accountNumber String?
  mpesaNumber String?
  mpesaRegisteredName String?
  payoutCompleted Boolean @default(false)
  acceptedTerms Boolean @default(false)
  acceptedPrivacy Boolean @default(false)
  confirmedAccurate Boolean @default(false)
  confirmedAuthorization Boolean @default(false)
  onboardingDraft String?
  ownerId     String
  owner       User      @relation("StoreOwner", fields: [ownerId], references: [id])
  products    Product[]
  orders      Order[]
  merchantPayoutEntries MerchantPayoutEntry[]
  zoneLinks   DeliveryZoneStore[]
  promotions  Promotion[]
  supportTickets SupportTicket[]
  pausedOrders Boolean @default(false)
  busyMode    Boolean @default(false)
  prepDelayMinutes Int?
  operatingHours String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([ownerId])
  @@index([category])
}

model DeliveryZone {
  id                  String   @id @default(uuid())
  name                String
  description         String?
  isActive            Boolean  @default(true)
  priority            Int      @default(100)
  minOrderValue       Float?
  baseDeliveryFee     Float    @default(0)
  perKmFee            Float?
  maxRadiusKm         Float?
  estimatedMinMinutes Int?
  estimatedMaxMinutes Int?
  polygon             String?  // JSON coordinates array
  metadata            String?  // JSON object with extra rule fields
  stores              DeliveryZoneStore[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([isActive])
  @@index([priority])
}

model DeliveryZoneStore {
  id        String       @id @default(uuid())
  zoneId    String
  storeId   String
  zone      DeliveryZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  store     Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([zoneId, storeId])
  @@index([zoneId])
  @@index([storeId])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  image       String
  category    String?
  available   Boolean  @default(true)
  quantityAvailable Int?
  lowStockThreshold Int?
  prepTimeOverride Int?
  maxQuantityPerOrder Int?
  sku         String?
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId])
  @@index([available])
}

model Order {
  id            String   @id @default(uuid())
  orderNumber   String?  @unique
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customerId    String
  customer      User     @relation("OrderCustomer", fields: [customerId], references: [id])
  driverId      String?
  status        String   @default("PENDING")
  total         Float
  deliveryFee   Float
  tax           Float    @default(0)
  deliveryOtp   String?
  deliveryOtpVerifiedAt DateTime?
  pickedUpAt    DateTime?
  deliveredAt   DateTime?
  customerInfo  String   // JSON string instead of Json type
  deliveryAddress String? // JSON string instead of Json type
  // Admin-managed fields
  cancellationReason  String?
  refundedAt          DateTime?
  refundAmount        Float?
  refundReason        String?
  rating              Float?
  ratingComment       String?
  merchantResponse    String?
  paymentStatus       String   @default("UNPAID")
  paymentProvider     String?
  paymentIntentRef    String?
  // Accounting snapshot fields persisted at delivery finalization.
  itemSubtotal        Float    @default(0)
  taxAmount           Float    @default(0)
  serviceFee          Float    @default(0)
  otherFees           Float    @default(0)
  customerTotal       Float    @default(0)
  merchantPlatformFee Float    @default(0)
  merchantNetPayout   Float    @default(0)
  driverPayout        Float    @default(0)
  platformDeliveryMargin Float @default(0)
  platformRevenue     Float    @default(0)
  payoutEligible      Boolean  @default(false)
  merchantPayoutStatus String  @default("PENDING")
  driverPayoutStatus   String  @default("PENDING")
  merchantPayoutBatchId String?
  driverPayoutBatchId   String?
  merchantPaidAt      DateTime?
  driverPaidAt        DateTime?
  items         OrderItem[]
  notes         OrderNote[]
  paymentIntent PaymentIntent?
  merchantPayoutEntries MerchantPayoutEntry[]
  driverPayoutEntries DriverPayoutEntry[]
  platformRevenueEntries PlatformRevenueEntry[]
  payoutBatchItems PayoutBatchItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  driver Driver?  @relation(fields: [driverId], references: [id])

  @@index([storeId])
  @@index([customerId])
  @@index([driverId])
  @@index([status])
  @@index([payoutEligible])
  @@index([merchantPayoutStatus])
  @@index([driverPayoutStatus])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float

  @@index([orderId])
  @@index([productId])
}

model Driver {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String
  vehicle   String
  license   String?
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  orders    Order[]
  payoutEntries DriverPayoutEntry[]
  available Boolean  @default(true)
  rating    Float    @default(5.0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([available])
}

model Category {
  id    String @id @default(uuid())
  name  String @unique
  image String?
  slug  String @unique
}

model Promotion {
  id        String    @id @default(uuid())
  title     String
  subtitle  String
  ctaText   String    @default("Order now")
  ctaLink   String?
  bgColor   String    @default("#FF5A5F")
  image     String?
  discountType String?
  discountValue Float?
  minOrderValue Float?
  usageLimit Int?
  usageCount Int @default(0)
  storeId   String?
  store     Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)
  active    Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([storeId])
}

model SupportTicket {
  id          String   @id @default(uuid())
  storeId      String?
  store        Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)
  merchantId   String?
  subject      String
  description  String
  category     String   @default("GENERAL")
  priority     String   @default("NORMAL")
  status       String   @default("OPEN")
  adminResponse String?
  attachmentUrls String?
  resolvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([storeId])
  @@index([merchantId])
  @@index([status])
  @@index([createdAt])
}

model BroadcastCampaign {
  id            String         @id @default(uuid())
  createdById   String
  title         String
  message       String
  channel       String         @default("IN_APP")
  audience      String         // ALL | CUSTOMERS | MERCHANTS | DRIVERS | USER_IDS
  audienceMeta  String?        // JSON metadata (filters / selected ids)
  status        String         @default("SENT")
  sentCount     Int            @default(0)
  failedCount   Int            @default(0)
  createdBy     User           @relation("BroadcastCreatedBy", fields: [createdById], references: [id])
  notifications Notification[]
  createdAt     DateTime       @default(now())

  @@index([createdById])
  @@index([audience])
  @@index([createdAt])
}

model Notification {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId  String?
  campaign    BroadcastCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  title       String
  message     String
  channel     String            @default("IN_APP")
  status      String            @default("SENT")
  readAt      DateTime?
  metadata    String?           // JSON string
  createdAt   DateTime          @default(now())

  @@index([userId])
  @@index([campaignId])
  @@index([createdAt])
}

// ─── Admin Audit Log ─────────────────────────────────────────────────────────
// Tracks every admin action for compliance and accountability.
model AdminAuditLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String   // e.g. ORDER_CANCELLED, DRIVER_SUSPENDED, REFUND_ISSUED
  entityType String   // ORDER | USER | DRIVER | STORE | PROMOTION | SYSTEM
  entityId   String?
  before     String?  // JSON snapshot of state before change
  after      String?  // JSON snapshot of state after change
  note       String?
  ip         String?
  createdAt  DateTime @default(now())

  admin User @relation("AdminAuditLogs", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([entityType])
  @@index([createdAt])
}

// ─── Order Notes ─────────────────────────────────────────────────────────────
// Internal notes added by admins to specific orders.
model OrderNote {
  id        String   @id @default(uuid())
  orderId   String
  adminId   String
  text      String
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  admin User  @relation("OrderNoteAdmin", fields: [adminId], references: [id])

  @@index([orderId])
}

model PaymentIntent {
  id             String   @id @default(uuid())
  customerId     String
  customer       User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderId        String?  @unique
  order          Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  provider       String
  providerRef    String?
  status         String   @default("REQUIRES_ACTION")
  amount         Float
  currency       String   @default("KES")
  idempotencyKey String?  @unique
  metadata       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([provider])
}

model PaymentEvent {
  id              String   @id @default(uuid())
  provider        String
  providerEventId String
  eventType       String
  payload         String
  processedAt     DateTime @default(now())
  createdAt       DateTime @default(now())

  @@unique([provider, providerEventId])
  @@index([provider])
  @@index([eventType])
  @@index([createdAt])
}

model PayoutLedger {
  id          String   @id @default(uuid())
  type        String
  orderId     String?
  storeId     String?
  storeName   String?
  driverId    String?
  driverName  String?
  cycleKey    String?
  amount      Float
  orderCount  Int?
  orderIds    String?
  note        String?
  actorUserId String?
  actorRole   String?
  source      String   @default("AUTO")
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([orderId])
  @@index([storeId])
  @@index([driverId])
  @@index([cycleKey])
  @@index([createdAt])
}

model MerchantPayoutEntry {
  id            String   @id @default(uuid())
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  amount         Float
  status         String   @default("PENDING")
  payoutBatchId  String?
  payoutBatch    PayoutBatch? @relation("MerchantBatch", fields: [payoutBatchId], references: [id], onDelete: SetNull)
  paidAt         DateTime?
  heldAt         DateTime?
  reversedAt     DateTime?
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([storeId])
  @@index([status])
  @@index([payoutBatchId])
  @@index([createdAt])
}

model DriverPayoutEntry {
  id            String   @id @default(uuid())
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driverId       String
  driver         Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  amount         Float
  status         String   @default("PENDING")
  payoutBatchId  String?
  payoutBatch    PayoutBatch? @relation("DriverBatch", fields: [payoutBatchId], references: [id], onDelete: SetNull)
  paidAt         DateTime?
  heldAt         DateTime?
  reversedAt     DateTime?
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([driverId])
  @@index([status])
  @@index([payoutBatchId])
  @@index([createdAt])
}

model PlatformRevenueEntry {
  id                    String   @id @default(uuid())
  orderId               String   @unique
  order                 Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  merchantPlatformFee   Float    @default(0)
  deliveryMargin        Float    @default(0)
  serviceFee            Float    @default(0)
  otherFees             Float    @default(0)
  totalRevenue          Float    @default(0)
  createdAt             DateTime @default(now())

  @@index([createdAt])
}

model PayoutBatch {
  id            String   @id @default(uuid())
  type          String
  recipientId   String
  recipientType String
  totalAmount   Float    @default(0)
  status        String   @default("PENDING")
  reference     String?
  notes         String?
  createdBy     String
  approvedBy    String?
  createdAt     DateTime @default(now())
  paidAt        DateTime?
  heldAt        DateTime?
  reversedAt    DateTime?
  merchantEntries MerchantPayoutEntry[] @relation("MerchantBatch")
  driverEntries DriverPayoutEntry[] @relation("DriverBatch")
  items         PayoutBatchItem[]

  @@index([type])
  @@index([recipientId])
  @@index([status])
  @@index([createdAt])
}

model PayoutBatchItem {
  id         String   @id @default(uuid())
  batchId    String
  batch      PayoutBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  entryId    String
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount     Float
  entryType  String
  createdAt  DateTime @default(now())

  @@unique([batchId, orderId, entryType])
  @@unique([entryType, entryId])
  @@index([orderId])
  @@index([entryType])
  @@index([createdAt])
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   // Stores JSON stringified data
  updatedAt DateTime @updatedAt
}
